---
import type { IExperiences } from "@types";

const { details } = Astro.props as IExperiences;
---

<section class="experience section" id="experience">
  <div class="site-container">
    <header class="section-header">
      <p class="section-label">01. Experience</p>
      <h2 class="section-title">Where I've worked</h2>
    </header>

    <div class="experience-layout" data-experience-tabs>
      <div class="tab-list" role="tablist" aria-label="Work experience">
        {
          details.map((item, index) => (
            <button
              type="button"
              class:list={["tab-btn", { active: index === 0 }]}
              role="tab"
              aria-selected={index === 0 ? "true" : "false"}
              aria-controls={`panel-${index}`}
              id={`tab-${index}`}
              data-tab={index}
            >
              <span class="tab-company">{item.company}</span>
              <span class="tab-role">{item.name}</span>
              <span class="tab-dates">
                {item.startDate} — {item.endDate}
              </span>
            </button>
          ))
        }
      </div>

      <div class="tab-panels">
        {
          details.map((item, index) => (
            <div
              class:list={["tab-panel", { active: index === 0 }]}
              role="tabpanel"
              id={`panel-${index}`}
              aria-labelledby={`tab-${index}`}
              data-panel={index}
              hidden={index !== 0}
            >
              <div class="panel-header">
                <div>
                  <h3 class="panel-role">{item.name}</h3>
                  <p class="panel-company">
                    {item.company} · {item.location}
                  </p>
                </div>
                <time class="panel-dates">
                  {item.startDate} — {item.endDate}
                </time>
              </div>

              {item.tech && item.tech.length > 0 && (
                <ul class="panel-tech" aria-label="Technologies used">
                  {item.tech.map((t) => (
                    <li>{t}</li>
                  ))}
                </ul>
              )}

              <ul class="panel-details">
                {item.description.map((desc) => (
                  <li>{desc}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function initExperienceTabs() {
    const root = document.querySelector("[data-experience-tabs]");
    if (!root) return;

    const tabs = root.querySelectorAll<HTMLButtonElement>("[data-tab]");
    const panels = root.querySelectorAll<HTMLElement>("[data-panel]");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const index = tab.dataset.tab;

        tabs.forEach((t) => {
          const isActive = t.dataset.tab === index;
          t.classList.toggle("active", isActive);
          t.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        panels.forEach((p) => {
          const isActive = p.dataset.panel === index;
          p.classList.toggle("active", isActive);
          if (isActive) {
            p.removeAttribute("hidden");
          } else {
            p.setAttribute("hidden", "");
          }
        });
      });
    });
  }

  initExperienceTabs();
  document.addEventListener("astro:page-load", initExperienceTabs);
</script>

<style>
  .section-header {
    margin-bottom: 1.75rem;
  }

  .experience-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  .tab-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    position: sticky;
    top: 5.5rem;
  }

  .tab-btn {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.125rem;
    padding: 0.875rem 1rem;
    background: transparent;
    border: none;
    border-left: 2px solid transparent;
    border-radius: 0 8px 8px 0;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
    width: 100%;
  }

  .tab-btn:hover {
    background: rgba(51, 210, 255, 0.05);
  }

  .tab-btn.active {
    border-left-color: #33d2ff;
    background: rgba(51, 210, 255, 0.08);
  }

  .tab-company {
    font-family: "Outfit", sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #333;
  }

  :global([data-theme="dark"]) .tab-company {
    color: #ccc;
  }

  .tab-btn.active .tab-company {
    color: #33d2ff;
  }

  .tab-role {
    font-size: 0.8125rem;
    color: #888;
  }

  .tab-dates {
    font-size: 0.75rem;
    color: #aaa;
    font-variant-numeric: tabular-nums;
  }

  :global([data-theme="dark"]) .tab-dates {
    color: #666;
  }

  .tab-panel {
    animation: fadeIn 0.25s ease;
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .panel-role {
    font-family: "Outfit", sans-serif;
    font-size: 1.375rem;
    font-weight: 600;
    color: #111;
    margin-bottom: 0.25rem;
  }

  :global([data-theme="dark"]) .panel-role {
    color: #fff;
  }

  .panel-company {
    font-size: 0.9375rem;
    color: #666;
  }

  :global([data-theme="dark"]) .panel-company {
    color: #888;
  }

  .panel-dates {
    font-size: 0.8125rem;
    color: #888;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .panel-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .panel-tech li {
    font-size: 0.75rem;
    font-weight: 500;
    color: #33d2ff;
    background: rgba(51, 210, 255, 0.08);
    border: 1px solid rgba(51, 210, 255, 0.15);
    padding: 0.3rem 0.625rem;
    border-radius: 4px;
  }

  .panel-details {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .panel-details li {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #444;
    padding-left: 1.25rem;
    position: relative;
  }

  :global([data-theme="dark"]) .panel-details li {
    color: #aaa;
  }

  .panel-details li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: #33d2ff;
    font-size: 0.75rem;
    top: 0.1rem;
  }

  @media (max-width: 640px) {
    .experience-layout {
      grid-template-columns: 1fr;
    }

    .tab-list {
      flex-direction: row;
      overflow-x: auto;
      position: static;
      gap: 0.5rem;
      padding-bottom: 0.5rem;
    }

    .tab-btn {
      border-left: none;
      border-bottom: 2px solid transparent;
      border-radius: 8px 8px 0 0;
      min-width: 140px;
      flex-shrink: 0;
    }

    .tab-btn.active {
      border-left-color: transparent;
      border-bottom-color: #33d2ff;
    }

    .panel-header {
      flex-direction: column;
    }
  }
</style>
