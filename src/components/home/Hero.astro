---
import { info } from "@data";
---

<section class="hero">
  <div class="site-container">
    <div class="hero-inner">
      <p class="hero-status">
        <span class="status-dot"></span>
        {info.availability}
      </p>

      <h1 class="hero-name">{info.name}</h1>

      <p class="hero-role">
        {info.jobTitle} at <span class="role-company">{info.jobContext}</span>
      </p>

      <p class="hero-tagline">{info.tagline}</p>

      <div class="hero-actions">
        <a href="#experience" class="btn btn-primary">
          View experience
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
        </a>
        <a href={info.socialMedia.github} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          GitHub
        </a>
        <a href={info.socialMedia.linkedin} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 75vh;
    display: flex;
    align-items: center;
    padding: 5.5rem 0 2rem;
  }

  .hero-inner {
    max-width: 40rem;
    animation: fadeInUp 0.7s ease forwards;
  }

  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #666;
    margin-bottom: 1rem;
  }

  :global([data-theme="dark"]) .hero-status {
    color: #888;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    background: #10b981;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero-name {
    font-family: "Outfit", sans-serif;
    font-size: clamp(2.75rem, 8vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #111;
    margin-bottom: 0.5rem;
  }

  :global([data-theme="dark"]) .hero-name {
    color: #fff;
  }

  .hero-role {
    font-size: 1.125rem;
    color: #555;
    margin-bottom: 0.75rem;
  }

  :global([data-theme="dark"]) .hero-role {
    color: #999;
  }

  .role-company {
    color: #33d2ff;
    font-weight: 500;
  }

  .hero-tagline {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #444;
    margin-bottom: 1.5rem;
    max-width: 34rem;
  }

  :global([data-theme="dark"]) .hero-tagline {
    color: #aaa;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (max-width: 480px) {
    .hero {
      min-height: auto;
      padding-top: 6rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
