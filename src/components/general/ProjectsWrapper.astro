---
import type { IProjects } from "@types";
import ProjectCard from "./ProjectCard.astro";

const { projects } = Astro.props as IProjects;
const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<section class="projects section" id="projects">
  <div class="site-container">
    <header class="section-header">
      <p class="section-label">02. Work</p>
      <h2 class="section-title">Side projects</h2>
      <p class="section-sub">
        Things I build outside of work — full products from API to UI.
      </p>
    </header>

    {
      featured.length > 0 && (
        <div class="featured-grid">
          {featured.map((project, index) => (
            <div class="featured-wrapper" style={`--delay: ${index * 0.1}s`}>
              <ProjectCard projectDetail={project} variant="featured" />
            </div>
          ))}
        </div>
      )
    }

    {
      rest.length > 0 && (
        <div class="projects-grid">
          {rest.map((project, index) => (
            <div class="project-wrapper" style={`--delay: ${(index + featured.length) * 0.08}s`}>
              <ProjectCard projectDetail={project} variant="default" />
            </div>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .section-header {
    margin-bottom: 1.75rem;
  }

  .section-sub {
    font-size: 1rem;
    color: #666;
    margin-top: 0.5rem;
    max-width: 28rem;
  }

  :global([data-theme="dark"]) .section-sub {
    color: #888;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .featured-wrapper,
  .project-wrapper {
    opacity: 0;
    animation: fadeInUp 0.5s ease forwards;
    animation-delay: var(--delay);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .featured-grid,
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
