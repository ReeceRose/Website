---
import { info } from "@data";
---

<nav class="nav" aria-label="Main navigation">
  <div class="site-container nav-container">
    <a href="/" class="nav-logo">
      {info.name.split(" ")[0]}<span class="text-blue">.</span>
    </a>

    <div class="nav-right">
      <div class="nav-links" id="nav-links">
        <a href="#experience" class="nav-link">Experience</a>
        <a href="#projects" class="nav-link">Work</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#contact" class="nav-link nav-link-cta">Contact</a>
      </div>

      <button
        type="button"
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle color theme"
      >
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button
        type="button"
        class="nav-toggle"
        id="nav-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-links"
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<script>
  function initNav() {
    const toggle = document.getElementById("nav-toggle");
    const links = document.getElementById("nav-links");
    const themeToggle = document.getElementById("theme-toggle");

    toggle?.addEventListener("click", () => {
      const isOpen = links?.classList.toggle("open");
      toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      toggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
    });

    links?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        links.classList.remove("open");
        toggle?.setAttribute("aria-expanded", "false");
        toggle?.setAttribute("aria-label", "Open menu");
      });
    });

    themeToggle?.addEventListener("click", () => {
      const isDark = document.documentElement.getAttribute("data-theme") === "dark";
      const next = isDark ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      localStorage.setItem("theme", next);
    });
  }

  initNav();
  document.addEventListener("astro:page-load", initNav);
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    background: rgba(250, 250, 250, 0.85);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  :global([data-theme="dark"]) .nav {
    background: rgba(10, 10, 10, 0.85);
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .nav-logo {
    font-family: "Outfit", sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #111;
    transition: opacity 0.2s;
  }

  :global([data-theme="dark"]) .nav-logo {
    color: #fff;
  }

  .nav-logo:hover {
    opacity: 0.7;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #666;
    padding: 0.5rem 0.875rem;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }

  :global([data-theme="dark"]) .nav-link {
    color: #999;
  }

  .nav-link:hover {
    color: #111;
    background: rgba(0, 0, 0, 0.04);
  }

  :global([data-theme="dark"]) .nav-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-link-cta {
    color: #33d2ff !important;
  }

  .nav-link-cta:hover {
    background: rgba(51, 210, 255, 0.1) !important;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    color: #666;
    cursor: pointer;
    transition: all 0.2s;
    margin-left: 0.5rem;
  }

  :global([data-theme="dark"]) .theme-toggle {
    border-color: rgba(255, 255, 255, 0.1);
    color: #999;
  }

  .theme-toggle:hover {
    border-color: #33d2ff;
    color: #33d2ff;
  }

  .icon-sun {
    display: none;
  }

  .icon-moon {
    display: block;
  }

  :global([data-theme="light"]) .icon-sun {
    display: block;
  }

  :global([data-theme="light"]) .icon-moon {
    display: none;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 8px;
    cursor: pointer;
    padding: 0 8px;
  }

  :global([data-theme="dark"]) .nav-toggle {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .nav-toggle span {
    display: block;
    height: 2px;
    background: #666;
    border-radius: 1px;
    transition: all 0.2s;
  }

  :global([data-theme="dark"]) .nav-toggle span {
    background: #999;
  }

  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      padding: 1rem 1.5rem 1.5rem;
      background: rgba(250, 250, 250, 0.97);
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
      gap: 0.25rem;
    }

    :global([data-theme="dark"]) .nav-links {
      background: rgba(10, 10, 10, 0.97);
      border-bottom-color: rgba(255, 255, 255, 0.06);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-link {
      padding: 0.75rem 1rem;
    }

    .nav-right {
      position: relative;
    }
  }
</style>
