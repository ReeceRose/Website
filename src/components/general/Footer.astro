---
import { info } from "@data";

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="site-container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          {info.name.split(" ")[0]}<span class="text-blue">.</span>
        </a>
        <p class="footer-tagline">{info.tagline}</p>
      </div>

      <div class="footer-links">
        <a href={info.socialMedia.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={info.socialMedia.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href={info.socialMedia.email}>Email</a>
      </div>
    </div>

    <p class="footer-copy">
      &copy; {currentYear} {info.name}
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: 2rem 0 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="dark"]) .footer {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-family: "Outfit", sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #111;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  :global([data-theme="dark"]) .footer-logo {
    color: #fff;
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #888;
    max-width: 28rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: #666;
    transition: color 0.2s;
  }

  :global([data-theme="dark"]) .footer-links a {
    color: #888;
  }

  .footer-links a:hover {
    color: #33d2ff;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: #aaa;
  }

  :global([data-theme="dark"]) .footer-copy {
    color: #555;
  }
</style>
