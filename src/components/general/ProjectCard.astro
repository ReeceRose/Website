---
import type { IProjectDetails } from "@types";

interface Props extends IProjectDetails {
  variant?: "default" | "featured";
}

const { projectDetail, variant = "default" } = Astro.props as Props;
const { title, tech, thumbnail, description, liveUrl, githubUrl, status } = projectDetail;
---

<article class:list={["project-card", { featured: variant === "featured" }]}>
  <a
    href={liveUrl || githubUrl || "#"}
    target="_blank"
    rel="noopener noreferrer"
    class="project-image-link"
    aria-label={`View ${title}`}
  >
    <div class="project-image">
      {status && <span class={`status-badge status-${status}`}>{status}</span>}
      <img src={thumbnail} loading="lazy" alt="" />
    </div>
  </a>

  <div class="project-content">
    <div class="project-header">
      <h3 class="project-title">
        {
          liveUrl ? (
            <a href={liveUrl} target="_blank" rel="noopener noreferrer">
              {title}
            </a>
          ) : (
            title
          )
        }
      </h3>
      <div class="project-links">
        {
          githubUrl && (
            <a
              href={githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="project-icon-link"
              aria-label={`${title} on GitHub`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
              </svg>
            </a>
          )
        }
        {
          liveUrl && (
            <a
              href={liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="project-icon-link"
              aria-label={`${title} live demo`}
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          )
        }
      </div>
    </div>

    {description && <p class="project-description">{description}</p>}

    {
      tech && tech.length > 0 && (
        <ul class="project-tech" aria-label="Technologies">
          {tech.map((t) => (
            <li>{t.title}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  .project-card {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
    background: #fff;
  }

  :global([data-theme="dark"]) .project-card {
    background: rgba(255, 255, 255, 0.02);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .project-card:hover {
    border-color: rgba(51, 210, 255, 0.3);
  }

  .project-image-link {
    display: block;
  }

  .project-image {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.04);
  }

  :global([data-theme="dark"]) .project-image {
    background: rgba(255, 255, 255, 0.04);
  }

  .project-card.featured .project-image {
    aspect-ratio: 16 / 8;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.03);
  }

  .status-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 1;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: rgba(251, 146, 60, 0.9);
    color: #fff;
  }

  .project-content {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.625rem;
  }

  .project-title {
    font-family: "Outfit", sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: #111;
  }

  :global([data-theme="dark"]) .project-title {
    color: #fff;
  }

  .project-title a {
    transition: color 0.2s;
  }

  .project-title a:hover {
    color: #33d2ff;
  }

  .project-links {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .project-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    color: #888;
    border: 1px solid rgba(0, 0, 0, 0.08);
    transition: all 0.2s;
  }

  :global([data-theme="dark"]) .project-icon-link {
    border-color: rgba(255, 255, 255, 0.08);
    color: #666;
  }

  .project-icon-link:hover {
    color: #33d2ff;
    border-color: #33d2ff;
  }

  .project-description {
    font-size: 0.875rem;
    line-height: 1.65;
    color: #666;
    margin-bottom: 1rem;
  }

  :global([data-theme="dark"]) .project-description {
    color: #888;
  }

  .project-card.featured .project-description {
    font-size: 0.9375rem;
  }

  .project-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .project-tech li {
    font-size: 0.6875rem;
    font-weight: 500;
    color: #33d2ff;
    background: rgba(51, 210, 255, 0.08);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }
</style>
